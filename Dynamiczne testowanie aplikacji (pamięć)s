package com.mycompany.mavenproject1;

import java.util.Arrays;
import java.math.BigInteger;

public class Mavenproject1 {

    private static final int MAKS_ZAKRES = 300000;

    public static void main(String[] args) {
        wbudowanyMechanizm(); 
        sitoEratostenesa();              
        sprawdzanieDoPierwiastka();      
        sprawdzanieDoPolowy();
        SprawdzanieWszystkich();
        
    }

    private static int sitoEratostenesa() {
        boolean[] pierwsze = new boolean[MAKS_ZAKRES + 1];
        Arrays.fill(pierwsze, true);
        int licznik = 0;

        for (int p = 2; p * p <= MAKS_ZAKRES; p++) {
            if (pierwsze[p]) {
                for (int i = p * p; i <= MAKS_ZAKRES; i += p) {
                    pierwsze[i] = false;
                }
            }
        }
        for (int i = 2; i <= MAKS_ZAKRES; i++) {
            if (pierwsze[i]) licznik++;
        }
        return licznik;
    }

    private static int sprawdzanieDoPierwiastka() {
        int licznik = 0;
        for (int i = 2; i <= MAKS_ZAKRES; i++) {
            boolean jestPierwsza = true;
            for (int j = 2; j * j <= i; j++) {
                if (i % j == 0) {
                    jestPierwsza = false;
                    break;
                }
            }
            if (jestPierwsza) licznik++;
        }
        return licznik;
    }

    private static int sprawdzanieDoPolowy() {
        int licznik = 0;
        for (int i = 2; i <= MAKS_ZAKRES; i++) {
            boolean jestPierwsza = true;
            int limit = i / 2;
            for (int j = 2; j <= limit; j++) {
                if (i % j == 0) {
                    jestPierwsza = false;
                    break;
                }
            }
            if (jestPierwsza) licznik++;
        }
        return licznik;
    }

    private static int SprawdzanieWszystkich() {
        int licznik = 0;
        for (int i = 2; i <= MAKS_ZAKRES; i++) {
            boolean jestPierwsza = true;
            for (int j = 2; j < i; j++) {
                if (i % j == 0) {
                    jestPierwsza = false;
                    break;
                }
            }
            if (jestPierwsza) licznik++;
        }
        return licznik;
    }
    private static int wbudowanyMechanizm() {
        int licznik = 0;
        for (int i = 2; i <= MAKS_ZAKRES; i++) {
            BigInteger liczba = BigInteger.valueOf(i);
            if (liczba.isProbablePrime(100)) {
                licznik++;
            }
        }
        return licznik;
    }

}
