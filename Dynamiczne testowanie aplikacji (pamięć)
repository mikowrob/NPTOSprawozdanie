class Element {
    final static int N = 200000;
    int[] tab;

    Element() {
        tab = new int[N];
        for (int i = 0; i < N; i++) {
            tab[i] = i * i;
        }
    }
}

class StosNaTablicy {
    private Element[] tab;
    private int size = 0;
    private static final int initSize = 100;

    public StosNaTablicy() {
        tab = new Element[initSize];
    }

    public void push(Element e) {
        if (size == tab.length) {
            tab = Arrays.copyOf(tab, 2 * size + 1);
        }
        tab[size++] = e;
    }

    public Element pop() {
        if (size > 0) {
            return tab[--size]; 
        } else {
            return null;
        }
    }

    public int size() {
        return size;
    }
}
